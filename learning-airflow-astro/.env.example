# Local PostgreSQL Connection Settings
# These credentials are used to connect to the local PostgreSQL database
# For local development with Astro CLI

# PostgreSQL Connection Details
POSTGRES_DEFAULT_CONN_ID=postgres_default
POSTGRES_DEFAULT_CONN_TYPE=postgres
POSTGRES_DEFAULT_HOST=postgres
POSTGRES_DEFAULT_PORT=5432
POSTGRES_DEFAULT_SCHEMA=postgres
POSTGRES_DEFAULT_LOGIN=postgres
POSTGRES_DEFAULT_PASSWORD=your_password_here
POSTGRES_DEFAULT_SSLMODE=disable

# Airflow Connection URI (used by Airflow to create connection from environment variable)
# Format: AIRFLOW_CONN_{connection_id}={connection_uri}
# This is the recommended way to define connections for production deployments
AIRFLOW_CONN_POSTGRES_DEFAULT=postgresql://username:password@host:5432/database?sslmode=disable
