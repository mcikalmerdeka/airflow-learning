# Neon PostgreSQL Connection Settings
# These credentials are used to connect to the Neon cloud PostgreSQL database
# Copy this file to .env and fill in your actual credentials

# PostgreSQL Connection Details
NEON_POSTGRES_CONN_ID=neon-postgres
NEON_POSTGRES_CONN_TYPE=postgres
NEON_POSTGRES_HOST=your-neon-host.aws.neon.tech
NEON_POSTGRES_PORT=5432
NEON_POSTGRES_SCHEMA=your_database_name
NEON_POSTGRES_LOGIN=your_username
NEON_POSTGRES_PASSWORD=your_password_here
NEON_POSTGRES_SSLMODE=require
NEON_POSTGRES_CHANNEL_BINDING=require

# Airflow Connection URI (used by Airflow to create connection from environment variable)
# Format: AIRFLOW_CONN_{connection_id}={connection_uri}
# This is the recommended way to define connections for production deployments
# Replace the values below with your actual credentials
AIRFLOW_CONN_NEON_POSTGRES=postgresql://username:password@host:5432/database?sslmode=require&channel_binding=require
