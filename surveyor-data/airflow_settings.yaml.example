# This file allows you to configure Airflow Connections, Pools, and Variables in a single place for local development only.
# NOTE: json dicts can be added to the conn_extra field as yaml key value pairs. See the example below.
# 
# IMPORTANT: Copy this file to airflow_settings.yaml and fill in your actual credentials from your .env file.
# The airflow_settings.yaml file should NOT be committed to git (it's in .gitignore).
#
# For more information, refer to our docs: https://www.astronomer.io/docs/astro/cli/develop-project#configure-airflow_settingsyaml-local-development-only

airflow:
  connections:
    - conn_id: neon-postgres
      conn_type: postgres
      conn_host: your-neon-host.aws.neon.tech
      conn_schema: your_database_name
      conn_login: your_username
      conn_password: your_password_here
      conn_port: 5432
      conn_extra:
        sslmode: require
        channel_binding: require
